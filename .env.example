# Default LLM backend
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# X / Twitter API v2 (Bearer Token from developer.x.com)
# Without this, X sources are silently skipped.
X_BEARER_TOKEN=

# Reserved for future providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub Issue Publisher.
#
# GITHUB_PUBLISH_TOKEN must be a Personal Access Token owned by the same
# account that owns the target repo. Using the default GITHUB_TOKEN
# (github-actions[bot]) is refused: issues need proper owner authorship
# for audit attribution and resume/demo consistency.
#
# Required scopes (classic PAT): repo (private repos) or public_repo (public).
# Fine-grained PAT: Issues = Read & Write on the target repo.
GITHUB_PUBLISH_TOKEN=
PUBLISH_REPO=your-github-handle/your-ai-daily-repo

# Optional: comma-separated label list applied to created issues.
# Overrides publish.default_labels in default.yaml when set.
PUBLISH_ISSUE_LABELS=

# ── Deprecated aliases (still accepted as fallbacks) ──────────────────────
# GITBLOG_OWNER_PAT=
# GITBLOG_REPO=
# GITBLOG_ISSUE_LABELS=
